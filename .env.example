# HN Pulse — environment variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control!
#
# The MCP server itself requires NO API keys (HN and Algolia APIs are public).
# Only the research agent requires an Anthropic API key.

# Required for agent/agent.py
ANTHROPIC_API_KEY=your_key_here
